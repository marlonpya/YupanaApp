# Plantilla de secrets de Yupana — COPIAR a `secrets.properties` y rellenar.
# `secrets.properties` está en .gitignore y NUNCA debe versionarse.
#
# Obtener estos valores en el dashboard de Supabase del proyecto:
#   Settings > API  (usar la PUBLISHABLE key `sb_publishable_...`, NO la anon key antigua)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
